\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Bimodal distribution of quarterly losses under unmanaged AI adoption ($G_0$). Normal quarters (grey, 92\%) peak near 250; crisis quarters (red, 8\%) peak near 1{,}600. $E[L] = 500$ falls in the near-empty gap $[600, 1200]$. Perceived $P_{99}$ (normal quarters only) $= 878$; actual $P_{99} = 1{,}714$ (solid red line). Crisis regime couples $\pi _t$ with $\xi _t$ (Basel~II conditional stress). $\mu _{\text  {crisis}}$, $\sigma _{\text  {normal}}$, $\sigma _{\text  {crisis}}$ are calibrated stylisations. \textit  {V5 coupled model, $M = 500$ replications, under model assumptions.}}}{19}{figure.caption.3}\protected@file@percent }
\newlabel{fig:bimodal}{{2}{19}{Bimodal distribution of quarterly losses under unmanaged AI adoption ($G_0$). Normal quarters (grey, 92\%) peak near 250; crisis quarters (red, 8\%) peak near 1{,}600. $E[L] = 500$ falls in the near-empty gap $[600, 1200]$. Perceived $P_{99}$ (normal quarters only) $= 878$; actual $P_{99} = 1{,}714$ (solid red line). Crisis regime couples $\pi _t$ with $\xi _t$ (Basel~II conditional stress). $\mu _{\text {crisis}}$, $\sigma _{\text {normal}}$, $\sigma _{\text {crisis}}$ are calibrated stylisations. \textit {V5 coupled model, $M = 500$ replications, under model assumptions.}}{figure.caption.3}{}}
