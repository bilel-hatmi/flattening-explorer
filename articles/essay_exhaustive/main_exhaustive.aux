\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Pairwise error correlation excess ($\hat  {C}_{\text  {excess}}$) under $G_0$ (red) and $G_2$ (green) over 20 quarters, with 95\% confidence intervals. Dotted line: no-AI baseline. Under $G_0$, correlation rises over five years, confirming the Wood et al.~\cite  {wood_jmlr_2023} mechanism in simulation. Under $G_2$, correlation remains below the no-AI baseline throughout. \textit  {V5 coupled model, $M = 200$ replications, under model assumptions.}}}{20}{figure.caption.5}\protected@file@percent }
\newlabel{fig:correlation}{{3}{20}{Pairwise error correlation excess ($\hat {C}_{\text {excess}}$) under $G_0$ (red) and $G_2$ (green) over 20 quarters, with 95\% confidence intervals. Dotted line: no-AI baseline. Under $G_0$, correlation rises over five years, confirming the Wood et al.~\cite {wood_jmlr_2023} mechanism in simulation. Under $G_2$, correlation remains below the no-AI baseline throughout. \textit {V5 coupled model, $M = 200$ replications, under model assumptions.}}{figure.caption.5}{}}
